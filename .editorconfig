# EditorConfig - Maintain consistent coding style
# https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Rust source code
[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

# TOML files (Cargo.toml, etc)
[*.toml]
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2



# Web files
[*.html]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.js]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

# Configuration files
[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

[*.conf]
indent_style = space
indent_size = 4

# Service files
[*.service]
indent_style = space
indent_size = 4

# Dockerfile
[Dockerfile]
indent_style = space
indent_size = 4

# Git files
[.gitignore]
indent_style = space
indent_size = 4

[.gitattributes]
indent_style = space
indent_size = 4

# Environment files
[.env*]
indent_style = space
indent_size = 4
